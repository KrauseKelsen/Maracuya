<resources>
    <declare-styleable name="MyLibraryThemeWrp">
        <attr name="useMaterial" format="boolean" />
        <attr name="themeStyle" format="string" />
        <attr name="themeName" format="string" />
    </declare-styleable>

    <declare-styleable name="PrimaryButtonWrp">
        <attr name="text" format="string" />
        <attr name="showProgressOnPress" format="boolean" />
        <attr name="isEnabled" format="boolean" />
    </declare-styleable>

    <declare-styleable name="ButtonWrp">
        <attr name="text" />
        <attr name="showProgressOnPress" />
        <attr name="isEnabled" />
        <attr name="buttonVariant" format="enum">
            <enum name="primary" value="0" />
            <enum name="secondary" value="1" />
        </attr>
        <attr name="buttonTokensOverride" format="string" />
    </declare-styleable>

    <declare-styleable name="ButtonNavigationWrp">
        <attr name="buttonNavigationLabel" format="string" />
        <attr name="isEnabled" />
        <attr name="buttonNavigationVariant" format="enum">
            <enum name="primary" value="0" />
            <enum name="secondary" value="1" />
        </attr>
        <attr name="buttonNavigationIsLoading" format="boolean" />
        <attr name="buttonNavigationStartsLoadingOnClick" format="boolean" />
        <attr name="buttonNavigationShowIcon" format="boolean" />
        <attr name="buttonNavigationTokensOverride" format="string" />
    </declare-styleable>

    <declare-styleable name="LabelWrp">
        <attr name="text" />
        <attr name="optionalText" format="boolean" />
        <attr name="showIcon" format="boolean" />
        <attr name="error" format="boolean" />
        <attr name="onClickContentDescription" format="string" />
        <attr name="labelTokensOverride" format="string" />
        <attr name="limitMaxLabel" format="boolean" />
    </declare-styleable>
    <declare-styleable name="TextFieldWrp">
        <attr name="textFieldValue" format="string" />
        <attr name="textFieldPinValue" format="string" />
        <attr name="textFieldLabel" format="string" />
        <attr name="textFieldPlaceholder" format="string" />
        <attr name="textFieldLength" format="string" />
        <attr name="isEnabled" />
        <attr name="textFieldReadOnly" format="boolean" />
        <attr name="textFieldHasError" format="boolean" />
        <attr name="optionalText" />
        <attr name="textFieldShowLabelIcon" format="boolean" />
        <attr name="textFieldBottomText" format="string" />
        <attr name="textFieldShowBottomIcon" format="boolean" />
        <attr name="textFieldVariant" format="string" />
        <attr name="textFieldEnableImplicitTrailingClear" format="boolean" />
        <attr name="textFieldTokensOverride" format="string" />
    </declare-styleable>

</resources>
